# ============================================================
# AI Agent Hub — n8n Webhook Configuration
# ============================================================
# Copy this file to .env and replace the placeholder URLs
# with your actual n8n webhook URLs.
#
# Each agent maps to a separate n8n workflow webhook.
# ============================================================

PORT=3000

# Agent 1 – Research Analyst
N8N_WEBHOOK_AGENT_1=https://your-n8n-instance.com/webhook/agent-1

# Agent 2 – Code Assistant
N8N_WEBHOOK_AGENT_2=https://your-n8n-instance.com/webhook/agent-2

# Agent 3 – Creative Writer
N8N_WEBHOOK_AGENT_3=https://your-n8n-instance.com/webhook/agent-3

# Agent 4 – Data Analyst
N8N_WEBHOOK_AGENT_4=https://your-n8n-instance.com/webhook/agent-4
